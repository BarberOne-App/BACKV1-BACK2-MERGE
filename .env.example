VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
=
DATABASE_URL=postgresql://usuario:senha@host:5432/database?sslmode=require
VITE_BARBERSHOP_SLUG=
=
FRONTEND_URL=http://localhost:5173

# AresChat Integration - modelo multi-tenant por credencial
# Defina um valor forte e mantenha estavel por ambiente antes de gerar tokens.
INTEGRATION_TOKEN_PEPPER=troque_por_um_valor_forte_e_estavel_por_ambiente
# URL publica completa da API de integracao exposta para o AresChat.
# Exemplo: https://api.parceiro.com.br/api/integrations/areschat/v1
ARESCHAT_INTEGRATION_BASE_URL=

# Login por WhatsApp usando AresChat como canal de envio do codigo.
# A URL de envio e o token da conexao WhatsApp sao salvos por barbearia
# via PUT /integrations/areschat/setup-data/outbound.
ARESCHAT_OUTBOUND_TOKEN_SECRET=troque_por_um_valor_forte_e_estavel_por_ambiente
WHATSAPP_LOGIN_OTP_TTL_MINUTES=5
WHATSAPP_LOGIN_OTP_MAX_ATTEMPTS=5
# Valor forte usado para hashear os codigos. Se vazio, usa INTEGRATION_TOKEN_PEPPER.
WHATSAPP_LOGIN_OTP_PEPPER=
# Placeholders aceitos: {{code}}, {{minutes}}, {{name}}, {{barbershop}}
WHATSAPP_LOGIN_OTP_MESSAGE_TEMPLATE=Seu codigo de acesso BarberOne e: {{code}}\n\nEle expira em {{minutes}} minutos. Nao compartilhe este codigo.
=
PAGARME_BASE_URL=https://api.pagar.me/core/v5
=
=
=
PAGARME_SECRET_KEY=
=
PAGARME_PLATFORM_RECIPIENT_ID=
PAGARME_PLATFORM_FEE_PERCENT=0.8
=
PAGARME_PIX_EXPIRES_IN=3600
PAGARME_STATEMENT_DESCRIPTOR=BARBERONE
=
# Configurações do E-mail SMTP 
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=
